    dct:source <https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES>,
        <https://www.w3.org/TR/prov-o/> ;
    rdfs:subClassOf prov:Activity ;
    skos:inScheme <https://markuswilhelmjahn.github.io/bblocks-pdes/> ;
    skos:prefLabel "Plankton RDA Simulation Run (PROV)" ;
    skos:topConceptOf <https://markuswilhelmjahn.github.io/bblocks-pdes/> ;
