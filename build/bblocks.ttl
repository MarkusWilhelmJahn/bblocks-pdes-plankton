<bblocks://mwj.pdes.simulation-run> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "Plankton RDA Simulation Run (PROV)" ;
    dct:abstract "PROV-O Activity capturing a single FDM simulation of the Scheffer phytoplankton/zooplankton RDA model, linking SOSA initial observations and parameters to output spatial fields and time series."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2025-01-01T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "text/markdown" ;
