{
  "@context": {
    "sosa":   "http://www.w3.org/ns/sosa/",
    "plkobs": "https://mwj.example.org/plankton/obs/",

    "ObservationCollection": "sosa:ObservationCollection",
    "featureOfInterest":     "sosa:hasFeatureOfInterest",
    "resultTime":            "sosa:resultTime",
    "phenomenonTime":        "sosa:phenomenonTime",
    "madeBySensor":          "sosa:madeBySensor",
    "observedProperties":    "sosa:hasResult",

    "X1_initial":             { "@id": "plkobs:phytoplanktonInitialDensity",   "@type": "sosa:ObservableProperty" },
    "X2_initial":             { "@id": "plkobs:zooplanktonInitialDensity",     "@type": "sosa:ObservableProperty" },
    "N_observed":             { "@id": "plkobs:nutrientLevel",                 "@type": "sosa:ObservableProperty" },
    "F_observed":             { "@id": "plkobs:fishPredationPressure",         "@type": "sosa:ObservableProperty" },
    "perturbation_amplitude": { "@id": "plkobs:perturbationAmplitude" },
    "perturbation_type":      { "@id": "plkobs:perturbationType" }
  }
}
