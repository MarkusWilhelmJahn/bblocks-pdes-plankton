{"defs":{},"properties":[{"path":["type"],"required":true,"const":"ObservationCollection","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest"],"id":"http://www.w3.org/ns/sosa/hasFeatureOfInterest","description":"The sampled water body or simulation spatial domain","required":true,"schema_type":"object","sources":["bblocks://mwj.pdes.observation"],"effectiveId":"http://www.w3.org/ns/sosa/hasFeatureOfInterest"},{"path":["featureOfInterest","type"],"required":true,"const":"Feature","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","geometry"],"description":"GeoJSON geometry of the domain. LineString for 1D, Polygon for 2D, Point for ODE.\n","required":true,"schema_type":"object","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","geometry","type"],"required":true,"schema_type":"string","enum":["Point","LineString","Polygon"],"sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","geometry","coordinates"],"required":true,"sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","properties"],"schema_type":"object","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","properties","name"],"schema_type":"string","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","properties","crs"],"schema_type":"string","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","properties","domainType"],"schema_type":"string","enum":["spatial-pde","phase-portrait-ode"],"sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","properties","gridDimensions"],"schema_type":"object","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","properties","gridDimensions","nx"],"schema_type":"integer","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","properties","gridDimensions","ny"],"schema_type":"integer","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","properties","gridDimensions","nz"],"schema_type":"integer","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","properties","gridSpacing"],"schema_type":"object","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","properties","gridSpacing","dx"],"schema_type":"number","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","properties","gridSpacing","dy"],"schema_type":"number","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","properties","gridSpacing","dz"],"schema_type":"number","sources":["bblocks://mwj.pdes.observation"]},{"path":["featureOfInterest","properties","initVtiFile"],"description":"Path or URI to the initial VTI file (step = 1)","schema_type":"string","sources":["bblocks://mwj.pdes.observation"]},{"path":["phenomenonTime"],"id":"http://www.w3.org/ns/sosa/phenomenonTime","description":"ISO 8601 time instant or interval \u2014 t = 0 of the simulation","required":true,"schema_type":"string","sources":["bblocks://mwj.pdes.observation"],"effectiveId":"http://www.w3.org/ns/sosa/phenomenonTime"},{"path":["madeBySensor"],"id":"http://www.w3.org/ns/sosa/madeBySensor","description":"URI or name of the sensor / instrument","required":true,"schema_type":"string","sources":["bblocks://mwj.pdes.observation"],"effectiveId":"http://www.w3.org/ns/sosa/madeBySensor"},{"path":["usedProcedure"],"id":"http://www.w3.org/ns/sosa/usedProcedure","jsonld_type":"@id","description":"URI of the PlanktonSimulationProcedure (sosa:usedProcedure)","schema_type":"string","sources":["bblocks://mwj.pdes.observation"],"effectiveId":"http://www.w3.org/ns/sosa/usedProcedure"},{"path":["hasMember"],"id":"http://www.w3.org/ns/sosa/hasMember","description":"One sosa:Observation per state variable. Minimum: phytoplankton (X1) and zooplankton (X2).\n","required":true,"schema_type":"array","sources":["bblocks://mwj.pdes.observation"],"effectiveId":"http://www.w3.org/ns/sosa/hasMember"},{"p