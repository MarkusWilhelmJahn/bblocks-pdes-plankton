<https://markuswilhelmjahn.github.io/bblocks-pdes-plankton/> a skos:ConceptScheme,
        dcat:Catalog,
        bblocks:BBlocksRegister ;
    rdfs:label "Building Blocks - Plankton RDA OGC Building Block Example" ;
    dct:abstract """A self-contained OGC Building Block example illustrating how SOSA, PROV-O
and STAC can be combined to describe a simulation model, its initial
conditions, parameter sets and result cataloguing — using the Scheffer (1991)
phytoplankton/zooplankton RDA model as a concrete case.
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:description """## About this Register

This register is an **example** showing how to apply OGC standards to
equation-based ecological simulation models. It is intentionally
self-contained and does not depend on any other building block register.

### What does this register contain?

- **simulation-run**: A `sosa:Procedure` describing how to execute the
  Scheffer RDA model in FiniteDifferenceMethod4PDES
- **observation**: A `sosa:ObservationCollection` providing initial
  phytoplankton and zooplankton conditions
- **parameters**: Typed Scheffer RDA parameter set
- **stac-result**: STAC Item cataloguing simulation outputs

### For Developers
* **[GitHub Repository](https://github.com/MarkusWilhelmJahn/bblocks-pdes-plankton)**
* **[OGC Blocks Documentation](https://ogcincubator.github.io/bblocks-docs/)**
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:modified "2026-06-17T08:25:41.815417"^^xsd:dateTime ;
    void:sparqlEndpoint <http://defs-hosted.opengis.net/fuseki-hosted/query> ;
    owl:imports <https://opengeospatial.github.io/bblocks/register.json> ;
    skos:hasTopConcept <bblocks://mwj.pdes.observation>,
        <bblocks://mwj.pdes.parameters>,
        <bblocks://mwj.pdes.simulation-domain>,
        <bblocks://mwj.pdes.simulation-run>,
        <bblocks://mwj.pdes.stac-result> ;
    skos:prefLabel "Building Blocks - Plankton RDA OGC Building Block Example" ;
    prof:hasResource [ rdfs:label "This Building Blocks Register in RDF Turtle format" ;
            dct:type "text/turtle" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://markuswilhelmjahn.github.io/bblocks-pdes-plankton/build/bblocks.ttl> ],
        [ rdfs:label "This Building Blocks Register in JSON format" ;
            dct:type "application/json" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://markuswilhelmjahn.github.io/bblocks-pdes-plankton/build/register.json> ],
        [ rdfs:label "This Building Blocks Register in JSON-LD format" ;
            dct:type "application/ld+json" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://markuswilhelmjahn.github.io/bblocks-pdes-plankton/build/bblocks.jsonld> ] ;
    foaf:homepage <https://markuswilhelmjahn.github.io/bblocks-pdes-plankton/> ;
    bblocks:hasValidationReport <https://markuswilhelmjahn.github.io/bblocks-pdes-plankton/build/tests/report.html> .

