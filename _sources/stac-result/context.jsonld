{
  "@context": {
    "sosa": "http://www.w3.org/ns/sosa/",
    "ssn":  "http://www.w3.org/ns/ssn/",
    "geo":  "http://www.opengis.net/ont/geosparql#",
    "type": "@type",
    "ObservationCollection": "sosa:ObservationCollection",
    "featureOfInterest": "sosa:hasFeatureOfInterest",
    "resultTime":         "sosa:resultTime",
    "phenomenonTime":     "sosa:phenomenonTime",
    "observedProperties": "sosa:hasResult",
    "X1_initial": {
      "@id": "https://example.org/plankton/obs/phytoplanktonDensity",
      "@type": "sosa:ObservableProperty"
    },
    "X2_initial": {
      "@id": "https://example.org/plankton/obs/zooplanktonDensity",
      "@type": "sosa:ObservableProperty"
    },
    "N_observed": {
      "@id": "https://example.org/plankton/obs/nutrientLevel",
      "@type": "sosa:ObservableProperty"
    }
  }
}