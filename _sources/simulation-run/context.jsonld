{
  "@context": {
    "prov":   "http://www.w3.org/ns/prov#",
    "sosa":   "http://www.w3.org/ns/sosa/",
    "ssn":    "http://www.w3.org/ns/ssn/",
    "dcat":   "http://www.w3.org/ns/dcat#",
    "rdfs":   "http://www.w3.org/2000/01/rdf-schema#",
    "xsd":    "http://www.w3.org/2001/XMLSchema#",
    "plksim": "https://mwj.example.org/plankton/sim/",

    "SimulationRun": {
      "@id": "prov:Activity",
      "@comment": "The simulation run is a prov:Activity, distinct from the sosa:Observation (which is also a prov:Activity but represents the field measurement)"
    },

    "id":    "@id",
    "label": "rdfs:label",

    "startedAtTime": {
      "@id":   "prov:startedAtTime",
      "@type": "xsd:dateTime"
    },
    "endedAtTime": {
      "@id":   "prov:endedAtTime",
      "@type": "xsd:dateTime"
    },

    "wasAssociatedWith": {
      "@id": "prov:wasAssociatedWith",
      "@comment": "The software agent (FiniteDifferenceMethod4PDES) that executed this Activity"
    },

    "used": {
      "@id": "prov:used",
      "@comment": "References both the SOSA ObservationCollection (initial conditions) and the parameter set. NOTE: sosa:usedProcedure ⊑ prov:used, but here we use prov:used directly because SimulationRun is a prov:Activity, not a sosa:Observation, and the observation is not a sosa:Procedure."
    },

    "parameters": {
      "@id": "prov:used",
      "@comment": "The parameter set Entity consumed by this Activity"
    },

    "generated": {
      "@reverse": "prov:wasGeneratedBy",
      "@comment": "Output assets (prov:Entity instances) generated by this Activity"
    },

    "numericalScheme":       "plksim:numericalScheme",
    "spatialDiscretisation": "plksim:spatialDiscretisation",
    "scenario":              "plksim:scenario",
    "stacItem":              "dcat:landingPage"
  }
}
