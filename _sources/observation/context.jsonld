{
  "@context": {
    "sosa":   "http://www.w3.org/ns/sosa/",
    "ssn":    "http://www.w3.org/ns/ssn/",
    "prov":   "http://www.w3.org/ns/prov#",
    "plkobs": "https://mwj.example.org/plankton/obs/",
    "xsd":    "http://www.w3.org/2001/XMLSchema#",

    "ObservationCollection": "sosa:ObservationCollection",

    "featureOfInterest": {
      "@id": "sosa:hasFeatureOfInterest",
      "@comment": "sosa:FeatureOfInterest ⊑ prov:Entity (SSN PROV alignment §6.5)"
    },

    "phenomenonTime": "sosa:phenomenonTime",

    "madeBySensor": {
      "@id": "sosa:madeBySensor",
      "@comment": "sosa:madeBySensor ⊑ prov:wasAssociatedWith; sosa:Sensor ⊑ prov:Agent"
    },

    "hasMember": {
      "@id": "sosa:hasMember",
      "@comment": "Each member is a sosa:Observation ⊑ prov:Activity"
    },

    "observedProperty": {
      "@id": "sosa:observedProperty",
      "@type": "@id",
      "@comment": "Links the Observation (prov:Activity) to its sosa:ObservableProperty"
    },

    "hasResult": {
      "@id": "sosa:hasResult",
      "@comment": "sosa:Result ⊑ prov:Entity; generated by the Observation prov:Activity"
    },

    "resultTime": {
      "@id": "sosa:resultTime",
      "@type": "xsd:dateTime"
    },

    "usedProcedure": {
      "@id": "sosa:usedProcedure",
      "@type": "@id",
      "@comment": "sosa:usedProcedure ⊑ prov:used; Procedure is the measurement protocol"
    },

    "value":  { "@id": "sosa:hasSimpleResult" },
    "unit":   { "@id": "http://qudt.org/schema/qudt/unit" },

    "perturbation":           { "@id": "https://mwj.example.org/plankton/sim/perturbation" },
    "perturbation_amplitude": { "@id": "https://mwj.example.org/plankton/sim/perturbationAmplitude" },
    "perturbation_type":      { "@id": "https://mwj.example.org/plankton/sim/perturbationType" },

    "ObservableProperties": {
      "@comment": "Canonical URIs for the four observable properties of the lake/mesocosm",
      "phytoplanktonDensity":  { "@id": "plkobs:phytoplanktonDensity",  "@type": "sosa:ObservableProperty" },
      "zooplanktonDensity":    { "@id": "plkobs:zooplanktonDensity",    "@type": "sosa:ObservableProperty" },
      "nutrientLevel":         { "@id": "plkobs:nutrientLevel",         "@type": "sosa:ObservableProperty" },
      "fishPredationPressure": { "@id": "plkobs:fishPredationPressure", "@type": "sosa:ObservableProperty" }
    }
  }
}
