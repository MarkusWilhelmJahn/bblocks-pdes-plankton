<bblocks://mwj.pdes.simulation-run> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "Plankton Simulation Procedure (SOSA)" ;
    dct:abstract "A sosa:Procedure describing how to execute the Scheffer (1991) phytoplankton/zooplankton RDA model in FiniteDifferenceMethod4PDES, specifying the model class, numerical solver, spatial domain and time discretisation."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2025-01-01T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://markuswilhelmjahn.github.io/bblocks-pdes-plankton/build/generateddocs/json-full/pdes/simulation-run/index.json> ],
        [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://markuswilhelmjahn.github.io/bblocks-pdes-plankton/bblock/mwj.pdes.simulation-run> ],
        [ dct:format "text/markdown" ;
