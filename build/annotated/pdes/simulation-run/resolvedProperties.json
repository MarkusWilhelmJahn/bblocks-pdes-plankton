{"defs":{},"properties":[{"path":["type"],"required":true,"const":"SimulationProcedure","sources":["bblocks://mwj.pdes.simulation-run"]},{"path":["id"],"id":"@id","description":"URI identifying this procedure","schema_type":"string","sources":["bblocks://mwj.pdes.simulation-run"],"effectiveId":"@id"},{"path":["label"],"id":"http://www.w3.org/2000/01/rdf-schema#label","description":"Human-readable label, e.g. 'Plankton-Euler-1D-Turing'","schema_type":"string","sources":["bblocks://mwj.pdes.simulation-run"],"effectiveId":"http://www.w3.org/2000/01/rdf-schema#label"},{"path":["modelClass"],"id":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#modelClass","description":"Java class implementing the Scheffer RDA model","required":true,"const":"model.lokal.o2.Plankton","sources":["bblocks://mwj.pdes.simulation-run"],"effectiveId":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#modelClass"},{"path":["software"],"id":"http://www.w3.org/ns/sosa/implementedBy","required":true,"schema_type":"object","sources":["bblocks://mwj.pdes.simulation-run"],"effectiveId":"http://www.w3.org/ns/sosa/implementedBy"},{"path":["software","id"],"id":"@id","required":true,"schema_type":"string","const":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES","sources":["bblocks://mwj.pdes.simulation-run"],"effectiveId":"@id"},{"path":["software","label"],"id":"http://www.w3.org/2000/01/rdf-schema#label","required":true,"schema_type":"string","const":"FiniteDifferenceMethod4PDES","sources":["bblocks://mwj.pdes.simulation-run"],"effectiveId":"http://www.w3.org/2000/01/rdf-schema#label"},{"path":["software","version"],"required":true,"schema_type":"string","sources":["bblocks://mwj.pdes.simulation-run"]},{"path":["numericalSolver"],"id":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#numericalSolver","description":"Time-integration solver class (model.numerik.*)","required":true,"schema_type":"string","enum":["jEuler","jRungeKutta","jButcher"],"sources":["bblocks://mwj.pdes.simulation-run"],"effectiveId":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#numericalSolver"},{"path":["dt"],"id":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#timeStep","jsonld_type":"http://www.w3.org/2001/XMLSchema#double","description":"Time step [d]","required":true,"schema_type":"number","sources":["bblocks://mwj.pdes.simulation-run"],"effectiveId":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#timeStep"},{"path":["t_end"],"id":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#endTime","jsonld_type":"http://www.w3.org/2001/XMLSchema#double","description":"Simulation end time [d]","required":true,"schema_type":"number","sources":["bblocks://mwj.pdes.simulation-run"],"effectiveId":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#endTime"},{"path":["simulationDomain"],"id":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#simulationDomain","jsonld_type":"@id","description":"URI of the PlanktonSimulationDomain (mwj.pdes.simulation-domain) defining the VTK Image Data grid","schema_type":"string","sources":["bblocks://mwj.pdes.simulation-run"],"effectiveId":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#simulationDomain"},{"path":["parameters"],"id":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#parameters","description":"Plankton RDA parameter set","sources":["bblocks://mwj.pdes.simulation-run"],"effectiveId":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#parameters"},{"path":["parameters","alpha"],"id":"https://mwj.example.org/plankton/model/maxPhytoplanktonGrowthRate","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Maximum phytoplankton growth rate [d^-1]. Default: 0.5","required":true,"schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/maxPhytoplanktonGrowthRate"},{"path":["parameters","c"],"id":"https://mwj.example.org/plankton/model/competitionCoefficient","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Phytoplankton intraspecific competition coefficient [mg.dw^-1 l d^-1]. Default: 0.05","required":true,"schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/competitionCoefficient"},{"path":["parameters","gamma"],"id":"https://mwj.example.org/plankton/model/maxGrazingRate","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Maximum zooplankton grazing rate on phytoplankton (Holling Type II) [d^-1]. Default: 0.4","required":true,"schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/maxGrazingRate"},{"path":["parameters","H1"],"id":"https://mwj.example.org/plankton/model/halfSatGrazing","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Half-saturation constant for zooplankton grazing [mg.dw l^-1]. Default: 0.6","required":true,"schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/halfSatGrazing"},{"path":["parameters","H2"],"id":"https://mwj.example.org/plankton/model/halfSatFishPredation","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Half-saturation constant for fish predation on zooplankton (Holling Type III) [mg.dw l^-1]. Default: 5.0","required":true,"schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/halfSatFishPredation"},{"path":["parameters","HN"],"id":"https://mwj.example.org/plankton/model/halfSatNutrient","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Half-saturation constant for nutrient-limited phytoplankton growth (Michaelis-Menten) [relative units]. Default: 1.0","required":true,"schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/halfSatNutrient"},{"path":["parameters","e"],"id":"https://mwj.example.org/plankton/model/assimilationEfficiency","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Zooplankton assimilation efficiency (dimensionless). Default: 0.6","required":true,"schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/assimilationEfficiency"},{"path":["parameters","delta"],"id":"https://mwj.example.org/plankton/model/zooplanktonMortalityRate","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Zooplankton mortality and respiration rate [d^-1]. Default: 0.175. Primary bifurcation parameter for ODE attractor type.","required":true,"schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/zooplanktonMortalityRate"},{"path":["parameters","N"],"id":"https://mwj.example.org/plankton/model/nutrientLevel","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Nutrient level \u2014 external control parameter (relative units). Default: 2.5","required":true,"schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/nutrientLevel"},{"path":["parameters","F"],"id":"https://mwj.example.org/plankton/model/fishPredationRate","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Fish predation rate on zooplankton [mg.dw d^-1 l^-1]. Default: 0.4","required":true,"schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/fishPredationRate"},{"path":["parameters","D1"],"id":"https://mwj.example.org/plankton/model/phytoplanktonDiffusivity","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Phytoplankton diffusion coefficient [cm^2 d^-1]. Turing scenario: D1=1e-5, D2=2e-3 (ratio 200). Travelling wave (DIFICI) scenario: D1=D2=1e-5.\n","required":true,"schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/phytoplanktonDiffusivity"},{"path":["parameters","D2"],"id":"https://mwj.example.org/plankton/model/zooplanktonDiffusivity","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Zooplankton diffusion coefficient [cm^2 d^-1]. Turing scenario: D1=1e-5, D2=2e-3. Travelling wave scenario: D1=D2=1e-5.\n","required":true,"schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/zooplanktonDiffusivity"},{"path":["parameters","v1x"],"id":"https://mwj.example.org/plankton/model/phytoplanktonAdvectionX","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Phytoplankton advection velocity in x-direction [cm d^-1]. Default: 0.0","schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/phytoplanktonAdvectionX"},{"path":["parameters","v2x"],"id":"https://mwj.example.org/plankton/model/zooplanktonAdvectionX","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Zooplankton advection velocity in x-direction [cm d^-1]. DIFICI (travelling waves) requires v1x - v2x != 0, e.g. 0.01. Default: 0.0\n","schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/zooplanktonAdvectionX"},{"path":["parameters","v1y"],"id":"https://mwj.example.org/plankton/model/phytoplanktonAdvectionY","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Phytoplankton advection velocity in y-direction [cm d^-1]. Default: 0.0","schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/phytoplanktonAdvectionY"},{"path":["parameters","v2y"],"id":"https://mwj.example.org/plankton/model/zooplanktonAdvectionY","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Zooplankton advection velocity in y-direction [cm d^-1]. Default: 0.0","schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/zooplanktonAdvectionY"},{"path":["parameters","domain_length_x_cm"],"description":"Spatial domain length in x [cm]. Script examples: 100 cm (1D), 50/100/150 cm (2D).","schema_type":"number"},{"path":["parameters","domain_length_y_cm"],"description":"Spatial domain length in y [cm]. Only for 2D runs.","schema_type":"number"},{"path":["parameters","grid_points_x"],"description":"Number of grid points in x-direction (FDM spatial discretisation).","schema_type":"integer"},{"path":["parameters","grid_points_y"],"description":"Number of grid points in y-direction. Only for 2D runs.","schema_type":"integer"},{"path":["parameters","dt"],"id":"https://mwj.example.org/plankton/model/numericalTimeStep","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Time step [d]. Must satisfy CFL condition for explicit FDM schemes.","schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/numericalTimeStep"},{"path":["parameters","t_end"],"id":"https://mwj.example.org/plankton/model/simulationEndTime","jsonld_type":"http://qudt.org/schema/qudt/Quantity","description":"Simulation end time [d].","schema_type":"number","effectiveId":"https://mwj.example.org/plankton/model/simulationEndTime"},{"path":["parameters","boundary_condition"],"id":"https://mwj.example.org/plankton/model/boundaryConditionType","description":"Spatial boundary condition type. zero-flux (Neumann, zero-gradient): used in Turing-structure runs. periodic: used on left/right boundary in travelling-wave run (Fig. 4.8).\n","schema_type":"string","enum":["zero-flux","periodic","dirichlet"],"effectiveId":"https://mwj.example.org/plankton/model/boundaryConditionType"},{"path":["parameters","spatial_dimensions"],"id":"https://mwj.example.org/plankton/model/spatialDimensions","description":"Number of spatial dimensions (1D or 2D).","schema_type":"integer","enum":[1,2],"effectiveId":"https://mwj.example.org/plankton/model/spatialDimensions"},{"path":["parameters","X1_0"],"description":"Initial phytoplankton density [mg.dw/l]. Default: 3.116","required":true,"schema_type":"number"},{"path":["parameters","X2_0"],"description":"Initial zooplankton density [mg.dw/l]. Default: 1.870","required":true,"schema_type":"number"},{"path":["scenario"],"id":"https://mwj.example.org/plankton/sim/scenario","description":"Qualitative scenario label","schema_type":"string","enum":["ODE-stable-node","ODE-stable-focus","ODE-limit-cycle","1D-Turing-standing-pattern","2D-Turing-standing-pattern","1D-DIFICI-travelling-wave","2D-DIFICI-travelling-wave"],"sources":["bblocks://mwj.pdes.simulation-run"],"effectiveId":"https://mwj.example.org/plankton/sim/scenario"},{"path":["spatialSetup"],"id":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#spatialSetup","description":"PDE spatial configuration \u2014 omit for pure ODE runs","schema_type":"object","sources":["bblocks://mwj.pdes.simulation-run"],"effectiveId":"https://github.com/MarkusWilhelmJahn/FiniteDifferenceMethod4PDES/ont#spatialSetup"},{"path":["spatialSetup","dimensions"],"schema_type":"integer","enum":[1,2],"sources":["bblocks://mwj.pdes.simulation-run"]},{"path":["spatialSetup","domain_length_x"],"description":"Domain length in x [cm]","schema_type":"number","sources":["bblocks://mwj.pdes.simulation-run"]},{"path":["spatialSetup","domain_length_y"],"description":"Domain length in y [cm] \u2014 2D only","schema_type":"number","sources":["bblocks://mwj.pdes.simulation-run"]},{"path":["spatialSetup","grid_points_x"],"schema_type":"integer","sources":["bblocks://mwj.pdes.simulation-run"]},{"path":["spatialSetup","grid_points_y"],"description":"2D only","schema_type":"integer","sources":["bblocks://mwj.pdes.simulation-run"]},{"path":["spatialSetup","boundary_condition"],"schema_type":"string","enum":["zero-flux","periodic","dirichlet"],"sources":["bblocks://mwj.pdes.simulation-run"]},{"path":["spatialSetup","diffusion"],"schema_type":"boolean","sources":["bblocks://mwj.pdes.simulation-run"]},{"path":["spatialSetup","advection"],"schema_type":"boolean","sources":["bblocks://mwj.pdes.simulation-run"]}]}