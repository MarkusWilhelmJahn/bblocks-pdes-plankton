<https://markuswilhelmjahn.github.io/bblocks-pdes/> a skos:ConceptScheme,
        dcat:Catalog,
        bblocks:BBlocksRegister ;
    rdfs:label "Building Blocks - Partial Differential Equation Systems OGC Blocks" ;
    dct:abstract """OGC Blocks implementation which uses the OGC standards SOSA, PROV and STAC combined to generate an interface for publishing the simulation results from a pytho-plankton and zoo-plankton interaction described by partial differential equations and numerically solved by using the Runge-Kutta method.
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:description """## About this Register:

### **Who is this register for?**

### **What does this register contain?**

### **When should this register be used?**

### **Where does this register fit?**

### **Why does this register exist?**

### **How is this register structured and implemented?**

### **For Developers**
*   **[GitHub Repository](https://github.com/ogcincubator/bblocks-SOSAPROVSTAC)**
*   **[OGC Blocks Documentation](https://ogcincubator.github.io/bblocks-docs/)**
*   **[OGC Blocks Tutorials](https://ogcincubator.github.io/bblocks-tutorial/)**
*   **[OGC Blocks Examples](https://ogcincubator.github.io/bblocks-examples/)**
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:modified "2026-05-20T12:34:30.558415"^^xsd:dateTime ;
    void:sparqlEndpoint <http://defs-hosted.opengis.net/fuseki-hosted/query> ;
    owl:imports <https://opengeospatial.github.io/bblocks/register.json> ;
    skos:hasTopConcept <bblocks://mwj.pdes.observation>,
        <bblocks://mwj.pdes.parameters>,
        <bblocks://mwj.pdes.simulation-run>,
        <bblocks://mwj.pdes.stac-result> ;
    skos:prefLabel "Building Blocks - Partial Differential Equation Systems OGC Blocks" ;
    prof:hasResource [ rdfs:label "This Building Blocks Register in RDF Turtle format" ;
            dct:type "text/turtle" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://markuswilhelmjahn.github.io/bblocks-pdes/build/bblocks.ttl> ],
        [ rdfs:label "This Building Blocks Register in JSON format" ;
            dct:type "application/json" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://markuswilhelmjahn.github.io/bblocks-pdes/build/register.json> ],
        [ rdfs:label "This Building Blocks Register in JSON-LD format" ;
            dct:type "application/ld+json" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://markuswilhelmjahn.github.io/bblocks-pdes/build/bblocks.jsonld> ] ;
    foaf:homepage <https://markuswilhelmjahn.github.io/bblocks-pdes/> ;
