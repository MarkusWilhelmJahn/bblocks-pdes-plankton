    {
      "itemIdentifier": "mwj.pdes.simulation-run",
      "name": "Plankton Simulation Procedure (SOSA)",
      "abstract": "A sosa:Procedure describing how to execute the Scheffer (1991) phytoplankton/zooplankton RDA model in FiniteDifferenceMethod4PDES, specifying the model class, numerical solver, spatial domain and time discretisation.",
